<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Community | Discord</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-main: #090a0f;
            --bg-card: #11131c;
            --border-color: rgba(255, 255, 255, 0.05);
            --text-main: #ffffff;
            --text-muted: #7e8396;
            --discord-color: #5865F2;
            --gradient-accent: linear-gradient(90deg, #5865F2, #8a46ff);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            overflow: hidden;
            position: relative;
        }

        .bg-glow {
            position: absolute;
            width: 300px;
            height: 300px;
            background: var(--discord-color);
            border-radius: 50%;
            filter: blur(150px);
            opacity: 0.15;
            z-index: 0;
            animation: pulse 6s infinite alternate;
        }

        @keyframes pulse {
            0% { transform: scale(1); opacity: 0.1; }
            100% { transform: scale(1.3); opacity: 0.2; }
        }

        .discord-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 50px 40px;
            width: 100%;
            max-width: 480px;
            text-align: center;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.7);
            position: relative;
            z-index: 1;
        }

        .icon-container {
            width: 80px;
            height: 80px;
            background: rgba(88, 101, 242, 0.1);
            border: 2px solid rgba(88, 101, 242, 0.3);
            border-radius: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0 auto 24px auto;
            box-shadow: 0 10px 25px rgba(88, 101, 242, 0.2);
        }

        .discord-icon {
            width: 45px;
            height: 45px;
            fill: var(--discord-color);
        }

        h1 {
            font-family: 'Poppins', sans-serif;
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 12px;
            background: var(--gradient-accent);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .subtitle {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 30px;
            line-height: 1.5;
        }

        .countdown-text {
            font-size: 0.9rem;
            color: var(--text-muted);
            margin-bottom: 20px;
        }

        #countdown {
            color: #fff;
            font-weight: 700;
        }

        .btn-join {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 12px;
            background: var(--discord-color);
            color: white;
            font-size: 1.1rem;
            font-weight: 700;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 20px rgba(88, 101, 242, 0.4);
        }

        .btn-join:hover {
            background: #4752C4;
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(88, 101, 242, 0.55);
        }
    </style>
</head>
<body>

<div class="bg-glow"></div>

<div class="discord-card">
    <div class="icon-container">
        <svg class="discord-icon" viewBox="0 0 127.14 96.36">
            <path d="M107.7,8.07A105.15,105.15,0,0,0,77.26,0a77.19,77.19,0,0,0-3.3,6.83A96.67,96.67,0,0,0,53.22,6.83,77.19,77.19,0,0,0,49.88,0,105.15,105.15,0,0,0,19.44,8.07C3.66,31.58-1.86,54.65,1,77.53A105.73,105.73,0,0,0,32,96.36a74.37,74.37,0,0,0,6.73-11,68.36,68.36,0,0,1-10.64-5.12c.91-.66,1.8-1.34,2.65-2a75.58,75.58,0,0,0,72.72,0c.85.69,1.74,1.37,2.65,2a68.44,68.44,0,0,1-10.64,5.12,74.74,74.74,0,0,0,6.73,11,105.73,105.73,0,0,0,31-18.83C130.1,49.22,124.2,26.47,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53S36.18,40.36,42.45,40.36,53.83,46,53.83,53,48.72,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.24,60,73.24,53S78.41,40.36,84.69,40.36,96.07,46,96.07,53,91,65.69,84.69,65.69Z"/>
        </svg>
    </div>

    <h1>Tritt dem Discord bei</h1>
    <p class="subtitle">Verbinde dich mit der Community, tausche dich aus und bleibe immer auf dem neuesten Stand.</p>

    <p class="countdown-text">Weiterleitung in <span id="countdown">3</span> Sekunden...</p>

    <a href="https://discord.gg/eVnUhwWnmJ" class="btn-join">Jetzt beitreten</a>
</div>

<script>
    const inviteUrl = "https://discord.gg/eVnUhwWnmJ";
    let seconds = 3;
    const countdownEl = document.getElementById('countdown');

    const interval = setInterval(() => {
        seconds--;
        countdownEl.innerText = seconds;
        
        if (seconds <= 0) {
            clearInterval(interval);
            window.location.href = inviteUrl;
        }
    }, 1000);
</script>

</body>
</html>
