{
  "version": 2,
  "redirects": [
    "COMMENT: ==================== SERVER SWITCH ====================",
    "STATUS: OFF = SERVERS DOWN (ACTIVE)",
    "INSTRUCTION: To turn servers ON, change the destination below to your main website domain, or delete this entire block.",
    {
      "source": "/(.*)",
      "destination": "https://servers-down.nicoprojects.dev",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/404"
    }
  ]
}
