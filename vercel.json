{
  "version": 2,
  "redirects": [
    {
      "_COMMENT": "==================== SERVER SWITCH ====================",
      "_STATUS": "OFF = SERVERS DOWN (ACTIVE)",
      "_INSTRUCTION": "To turn servers ON, change the destination below to your main website domain, or delete this entire block.",
      "source": "/(.*)",
      "destination": "https://servers-down.nicoprojects.dev",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/404"
    }
  ]
}
