{
  "version": 2,
  "redirects": [
    {
      "COMMENT": "==================== SERVER SWITCH ====================",
      "STATUS": "OFF = SERVERS DOWN (ACTIVE)",
      "INSTRUCTION": "To turn servers ON, delete this entire block (lines 4 through 11).",
      "source": "/(.*)",
      "destination": "https://servers-down.nicoprojects.dev",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/404"
    }
  ]
}
